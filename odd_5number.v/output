#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5a5eeaf7f4d0 .scope module, "tb_odd_random" "tb_odd_random" 2 1;
 .timescale 0 0;
S_0x5a5eeaf7f660 .scope module, "uut" "odd_random" 2 2, 3 1 0, S_0x5a5eeaf7f4d0;
 .timescale 0 0;
v0x5a5eeaf6cfe0_0 .var/i "count", 31 0;
v0x5a5eeaf8f770_0 .var/i "num", 31 0;
    .scope S_0x5a5eeaf7f660;
T_0 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5a5eeaf6cfe0_0, 0, 32;
T_0.0 ;
    %load/vec4 v0x5a5eeaf6cfe0_0;
    %cmpi/s 5, 0, 32;
    %jmp/0xz T_0.1, 5;
    %vpi_func 3 8 "$urandom_range" 32, 32'sb00000000000000000000000000000001, 32'sb00000000000000000000000000001010 {0 0 0};
    %store/vec4 v0x5a5eeaf8f770_0, 0, 32;
    %load/vec4 v0x5a5eeaf8f770_0;
    %pushi/vec4 2, 0, 32;
    %mod/s;
    %cmpi/ne 0, 0, 32;
    %jmp/0xz  T_0.2, 4;
    %vpi_call 3 11 "$display", "Random odd number = %0d", v0x5a5eeaf8f770_0 {0 0 0};
    %load/vec4 v0x5a5eeaf6cfe0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5a5eeaf6cfe0_0, 0, 32;
T_0.2 ;
    %jmp T_0.0;
T_0.1 ;
    %end;
    .thread T_0;
    .scope S_0x5a5eeaf7f4d0;
T_1 ;
    %vpi_call 2 4 "$display", "5 Odd Random Numbers between 1 and 10" {0 0 0};
    %delay 100, 0;
    %vpi_call 2 6 "$finish" {0 0 0};
    %end;
    .thread T_1;
